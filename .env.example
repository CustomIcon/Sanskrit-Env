# Cloudflare Workers AI credentials
CLOUDFLARE_API_TOKEN=cf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hugging Face token for fallback when Cloudflare is rate-limited
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_ROUTER_URL=https://router.huggingface.co/v1/chat/completions

# Environment endpoint selection
# space -> prefer HF Space first, then fall back to local
# local -> prefer local first, then fall back to HF Space
# auto  -> keep configured URL order, then fall back to defaults
SANSKRIT_ENV_TARGET=space

# Hugging Face Space endpoint used by inference.py when targeting the deployed env
HF_SPACE_URL=https://adityahars-sanskrit-env.hf.space

# Optional local environment URL used when SANSKRIT_ENV_TARGET=local or as fallback
SANSKRIT_ENV_URL=http://localhost:7860

# Optional explicit endpoint override.
# Leave empty to auto-build from CLOUDFLARE_ACCOUNT_ID:
# https://api.cloudflare.com/client/v4/accounts/<ACCOUNT_ID>/ai/v1/chat/completions
CF_CHAT_COMPLETIONS_URL=

# Generation settings
CF_TEMPERATURE=0.0
CF_MAX_TOKENS=512
CF_REQUEST_TIMEOUT=90
HF_MAX_TOKENS=512
HF_REQUEST_TIMEOUT=90
HF_RETRY_WAIT=5
RETRY_WAIT=5

# Baseline run controls (env-driven; no CLI args required)
# all | glossary_anchoring | sandhi_resolution | samasa_classification | referential_coherence
BASELINE_TASK=all

# Single baseline model selector (only model selection env var used by baseline.py)
BASELINE_MODEL=@cf/meta/llama-3.1-8b-instruct

EPISODES_PER_TASK=5
RANDOM_SEED=42
